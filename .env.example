# Discord Bot Token
# Obtain this from the Discord Developer Portal
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Guild (Server) ID
# Used to register slash commands immediately to a specific server.
# Leave as 'your_guild_id_here' to register globally (can take up to 1 hour to propagate).
GUILD_ID=your_guild_id_here

# Application Logging Level
# Options: DEBUG, INFO, WARN, ERROR
# Determines the verbosity of the console output.
LOG_LEVEL=INFO

# LowDB AES Encryption Key
# 32-byte hex string used to encrypt restore codes in db.json.
# If left blank or default, the application will automatically generate a secure key on first run.
ENCRYPTION_KEY=default_secret_please_change

# Discord Log Channel ID
# Fallback channel ID for bot notifications if not set dynamically via /set_log_channel
LOG_CHANNEL_ID=your_channel_id_here
