# =============================================================================
# Evertext Automation Framework — Environment Configuration
# Copy this file to `.env` and fill in your values.
# =============================================================================

# -----------------------------------------------------------------------------
# DISCORD_TOKEN (required)
# Bot token from the Discord Developer Portal → Bot → Token
# Example: DISCORD_TOKEN=MTxxxxxxxxxxxxxxxxxxxxx.xxxxxx.xxxxxxxxxxxxxxxxxxxxx
# -----------------------------------------------------------------------------
DISCORD_TOKEN=your_discord_bot_token_here

# -----------------------------------------------------------------------------
# GUILD_ID (optional)
# Discord server (guild) ID for instant slash-command registration.
# Leave as placeholder to register commands globally (can take up to 1 hour).
# Where: Discord → Server Settings → Widget → Server ID
# -----------------------------------------------------------------------------
GUILD_ID=your_guild_id_here

# -----------------------------------------------------------------------------
# LOG_LEVEL (optional, default: INFO)
# Console verbosity: DEBUG | INFO | WARN | ERROR
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# ENCRYPTION_KEY (recommended)
# AES key for encrypting restore codes in db.json.
# Use a random 32-byte hex string. If unset or default, one is auto-generated
# on first run and appended to `.env`.
# Example: ENCRYPTION_KEY=a1b2c3d4e5f6789012345678901234567890abcdef1234567890abcdef123456
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=default_secret_please_change

# -----------------------------------------------------------------------------
# LOG_CHANNEL_ID (optional)
# Fallback Discord channel ID for bot notifications when not set via
# /set_log_channel. Enable Developer Mode → right-click channel → Copy ID.
# -----------------------------------------------------------------------------
LOG_CHANNEL_ID=your_channel_id_here

# -----------------------------------------------------------------------------
# PORT (optional, default: 3000)
# HTTP port for the health-check server (/health, /ping).
# Used by container orchestrators (Docker, Zeabur, etc.).
# -----------------------------------------------------------------------------
PORT=3000
